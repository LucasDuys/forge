# Forge runtime state (per-project, not part of the plugin)
.forge/
# TUI dashboard log — explicit entry for discoverability (already covered above)
.forge/.tui-log.jsonl
# Mock fixtures ship their own .forge/ configs + specs as tracked fixture data.
# Per-mock .gitignore still excludes runtime state like .forge/baselines/.
!mock-projects/**/.forge/
!mock-projects/**/.forge/**

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Node (shouldn't have any, but just in case)
node_modules/

# Claude Code local settings
.claude/settings.local.json
